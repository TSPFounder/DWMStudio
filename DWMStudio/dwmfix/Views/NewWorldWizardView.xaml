<UserControl x:Class="DWMStudio.Views.NewWorldWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="New World"
                       Style="{StaticResource SectionHeaderStyle}" FontSize="18" />
            <TextBlock Style="{StaticResource MutedLabelStyle}" Margin="0 4 0 0">
                <Run Text="Step " />
                <Run Text="{Binding CurrentStep}" />
                <Run Text=" of " />
                <Run Text="{Binding TotalSteps}" />
            </TextBlock>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="0 20">

            <!-- Step 1: name + description -->
            <StackPanel Visibility="{Binding CurrentStep,
                Converter={StaticResource StepVisibilityConverter}, ConverterParameter=1}">
                <TextBlock Text="World name" Style="{StaticResource MutedLabelStyle}" Margin="0 0 0 6" />
                <TextBox Text="{Binding WorldName, UpdateSourceTrigger=PropertyChanged}"
                         Background="#1A1D21" Foreground="#C8D0DC"
                         BorderBrush="{StaticResource DwmDividerBrush}"
                         Padding="8 6" FontSize="14" Margin="0 0 0 14" />
                <TextBlock Text="Description" Style="{StaticResource MutedLabelStyle}" Margin="0 0 0 6" />
                <TextBox Text="{Binding WorldDescription, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                         Background="#1A1D21" Foreground="#C8D0DC"
                         BorderBrush="{StaticResource DwmDividerBrush}" Padding="8" />
            </StackPanel>

            <!-- Step 2 -->
            <StackPanel Visibility="{Binding CurrentStep,
                Converter={StaticResource StepVisibilityConverter}, ConverterParameter=2}">
                <TextBlock Text="Architecture &amp; CAD setup happens after creation."
                           Style="{StaticResource MutedLabelStyle}" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Step 3 -->
            <StackPanel Visibility="{Binding CurrentStep,
                Converter={StaticResource StepVisibilityConverter}, ConverterParameter=3}">
                <TextBlock Text="Ready to create your world."
                           Foreground="{StaticResource DwmSuccessBrush}" FontSize="13" />
            </StackPanel>

        </StackPanel>

        <!-- Nav buttons -->
        <Grid Grid.Row="2">
            <Button Content="← Back"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Left"
                    IsEnabled="{Binding CanGoBack}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding DataContext.CloseWizardCommand,
                            RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource GhostButtonStyle}" Margin="0 0 8 0" />
                <Button Content="Next →"
                        Command="{Binding NextCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Visibility="{Binding CanGoNext,
                            Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Content="Create World"
                        Command="{Binding CreateWorldCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Visibility="{Binding CanGoNext,
                            Converter={StaticResource InverseBoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
