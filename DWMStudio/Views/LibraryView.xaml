<UserControl x:Class="DWMStudio.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DWMStudio.ViewModels"
             Background="{StaticResource DwmShellBrush}">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="32 24 32 12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Asset Library"
                               Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Style="{StaticResource MutedLabelStyle}" Margin="0 4 0 0">
                        <Run Text="{Binding Collections.Count, Mode=OneWay}" />
                        <Run Text="collections" />
                    </TextBlock>
                </StackPanel>

                <Border HorizontalAlignment="Right"
                        Background="{StaticResource DwmCardBrush}"
                        CornerRadius="4" Padding="10 0"
                        Width="240" Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource DwmMutedBrush}"
                                   Margin="0 0 6 0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderBrush="Transparent"
                                 Foreground="#E0E4EC" CaretBrush="#E0E4EC"
                                 VerticalAlignment="Center" FontSize="13" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Two-panel split -->
        <Grid Margin="32 0 32 32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Collections list -->
            <Border Grid.Column="0"
                    Background="{StaticResource DwmCardBrush}"
                    CornerRadius="6"
                    Margin="0 0 12 0">
                <ListBox ItemsSource="{Binding Collections}"
                         SelectedItem="{Binding SelectedCollection}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12 10" />
                            <Setter Property="Foreground" Value="#C8D0DC" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2A2F37" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E2228" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E0E4EC"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Style="{StaticResource MutedLabelStyle}"
                                           Margin="0 2 0 0">
                                    <Run Text="{Binding Publisher, Mode=OneWay}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding ImportStatusLabel, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Assets in selected collection -->
            <Border Grid.Column="1"
                    Background="{StaticResource DwmCardBrush}"
                    CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <ItemsControl ItemsSource="{Binding Assets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1D21"
                                        CornerRadius="4"
                                        Width="150" Height="120"
                                        Margin="0 0 10 10">
                                    <Grid>
                                        <TextBlock Text="{Binding AssetType}"
                                                   FontSize="9"
                                                   FontFamily="{StaticResource DwmMonoFont}"
                                                   Foreground="{StaticResource DwmMutedBrush}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Margin="8" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="11"
                                                   Foreground="#C8D0DC"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Bottom"
                                                   Margin="8" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </Grid>
    </DockPanel>
</UserControl>
