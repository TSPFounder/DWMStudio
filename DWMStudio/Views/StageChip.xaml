<UserControl x:Class="DWMStudio.Views.StageChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border CornerRadius="3" Padding="6 2">
        <Border.Style>
            <Style TargetType="Border">
                <!-- Default: dim background when not complete -->
                <Setter Property="Background" Value="#1A1D21" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsComplete, ElementName=Root}" Value="True">
                        <Setter Property="Background"
                                Value="{Binding ChipColor, ElementName=Root}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <TextBlock Text="{Binding Label, ElementName=Root}"
                   FontFamily="{StaticResource DwmMonoFont}"
                   FontSize="9">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource DwmMutedBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsComplete, ElementName=Root}" Value="True">
                            <Setter Property="Foreground" Value="#111418" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Border>
</UserControl>
