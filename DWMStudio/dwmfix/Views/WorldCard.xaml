<UserControl x:Class="DWMStudio.Views.WorldCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border Style="{StaticResource WorldCardStyle}">
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick"
                          Command="{Binding OpenWorldCommand, ElementName=Root}"
                          CommandParameter="{Binding}" />
        </Border.InputBindings>

        <StackPanel>
            <!-- Thumbnail -->
            <Border Height="110" CornerRadius="6 6 0 0" Background="#1A2430">
                <TextBlock Text="DWM"
                           FontFamily="{StaticResource DwmDisplayFont}"
                           FontSize="32" FontWeight="Bold" Opacity="0.08"
                           Foreground="{StaticResource DwmCadBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- Pipeline strip: 5 stage colours, dim until complete -->
            <Grid Height="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="0" Fill="{StaticResource DwmSysmlBrush}"
                           Opacity="{Binding Stages[0].IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="1" Fill="{StaticResource DwmCadBrush}"
                           Opacity="{Binding Stages[1].IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="2" Fill="{StaticResource DwmSimBrush}"
                           Opacity="{Binding Stages[2].IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="3" Fill="{StaticResource DwmCoSimBrush}"
                           Opacity="{Binding Stages[3].IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="4" Fill="{StaticResource DwmRuntimeBrush}"
                           Opacity="{Binding Stages[4].IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
            </Grid>

            <!-- Content -->
            <StackPanel Margin="14 12 14 14">
                <TextBlock Text="{Binding Name}"
                           FontFamily="{StaticResource DwmBodyFont}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#E0E4EC"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Description}"
                           Style="{StaticResource MutedLabelStyle}"
                           TextWrapping="Wrap" MaxHeight="32"
                           TextTrimming="CharacterEllipsis"
                           Margin="0 4 0 10" />
                <Grid>
                    <TextBlock Style="{StaticResource MutedLabelStyle}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding CompletedStageCount, Mode=OneWay}" />
                        <Run Text="/ 5 stages" />
                    </TextBlock>
                    <Button Content="Open →"
                            HorizontalAlignment="Right"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding OpenWorldCommand, ElementName=Root}"
                            CommandParameter="{Binding}" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
