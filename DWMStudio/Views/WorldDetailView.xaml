<UserControl x:Class="DWMStudio.Views.WorldDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DWMStudio.Views"
             Background="{StaticResource DwmShellBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32 24">
        <StackPanel>

            <!-- Header -->
            <TextBlock Text="{Binding World.Name}"
                       Style="{StaticResource SectionHeaderStyle}" />
            <TextBlock Text="{Binding World.Description}"
                       Style="{StaticResource MutedLabelStyle}"
                       TextWrapping="Wrap"
                       Margin="0 4 0 0" />

            <!-- Pipeline strip (large) -->
            <Grid Height="6" Margin="0 16 0 24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="0" RadiusX="2" RadiusY="2"
                           Fill="{StaticResource DwmSysmlBrush}"
                           Opacity="{Binding SysmlStage.IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="2" RadiusX="2" RadiusY="2"
                           Fill="{StaticResource DwmCadBrush}"
                           Opacity="{Binding CadStage.IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="4" RadiusX="2" RadiusY="2"
                           Fill="{StaticResource DwmSimBrush}"
                           Opacity="{Binding MatlabStage.IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="6" RadiusX="2" RadiusY="2"
                           Fill="{StaticResource DwmCoSimBrush}"
                           Opacity="{Binding CoSimStage.IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
                <Rectangle Grid.Column="8" RadiusX="2" RadiusY="2"
                           Fill="{StaticResource DwmRuntimeBrush}"
                           Opacity="{Binding RuntimeStage.IsComplete,
                               Converter={StaticResource BoolToOpacityConverter}}" />
            </Grid>

            <!-- Stage panels -->
            <UniformGrid Columns="2">

                <!-- SysML -->
                <Border Style="{StaticResource WorldCardStyle}" Cursor="Arrow" Margin="0 0 12 12">
                    <StackPanel Margin="16">
                        <TextBlock Text="SysML / Architecture"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource DwmSysmlBrush}" />
                        <TextBlock Margin="0 6 0 0" Style="{StaticResource MutedLabelStyle}">
                            <Run Text="{Binding World.RequirementCount, Mode=OneWay}" />
                            <Run Text="requirements, " />
                            <Run Text="{Binding World.ActorCount, Mode=OneWay}" />
                            <Run Text="actors, " />
                            <Run Text="{Binding World.UseCaseCount, Mode=OneWay}" />
                            <Run Text="use cases" />
                        </TextBlock>
                        <Button Content="Open in UModel"
                                Command="{Binding OpenInUModelCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0 12 0 0" />
                    </StackPanel>
                </Border>

                <!-- CAD -->
                <Border Style="{StaticResource WorldCardStyle}" Cursor="Arrow" Margin="0 0 0 12">
                    <StackPanel Margin="16">
                        <TextBlock Text="CAD / Fusion 360"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource DwmCadBrush}" />
                        <TextBlock Text="{Binding World.FusionDocumentPath,
                                       FallbackValue='No Fusion document linked'}"
                                   Style="{StaticResource MutedLabelStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0 6 0 0" />
                        <Button Content="Open in Fusion"
                                Command="{Binding OpenInFusionCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0 12 0 0" />
                    </StackPanel>
                </Border>

                <!-- MATLAB -->
                <Border Style="{StaticResource WorldCardStyle}" Cursor="Arrow" Margin="0 0 12 12">
                    <StackPanel Margin="16">
                        <TextBlock Text="MATLAB / Simulink"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource DwmSimBrush}" />
                        <TextBlock Text="{Binding World.SimulinkModelPath,
                                       FallbackValue='Model not built yet'}"
                                   Style="{StaticResource MutedLabelStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0 6 0 0" />
                        <Button Content="Build Simulink Model"
                                Command="{Binding BuildSimulinkModelCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0 12 0 0" />
                    </StackPanel>
                </Border>

                <!-- UE -->
                <Border Style="{StaticResource WorldCardStyle}" Cursor="Arrow" Margin="0 0 0 12">
                    <StackPanel Margin="16">
                        <TextBlock Text="Unreal Engine"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource DwmRuntimeBrush}" />
                        <TextBlock Text="Co-simulation and runtime"
                                   Style="{StaticResource MutedLabelStyle}"
                                   Margin="0 6 0 0" />
                        <Button Content="Launch in Unreal"
                                Command="{Binding OpenInUnrealCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0 12 0 0" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Status line -->
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource MutedLabelStyle}"
                       Margin="0 8 0 0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
