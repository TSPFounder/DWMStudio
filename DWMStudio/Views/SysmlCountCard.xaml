<UserControl x:Class="DWMStudio.Views.SysmlCountCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border Background="#161920" CornerRadius="6" Padding="16 14">
        <StackPanel>
            <TextBlock Text="{Binding Count, ElementName=Root}"
                       FontFamily="{StaticResource DwmDisplayFont}"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{Binding Colour, ElementName=Root}" />
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       Style="{StaticResource MutedLabelStyle}"
                       Margin="0 2 0 0" />
        </StackPanel>
    </Border>
</UserControl>
