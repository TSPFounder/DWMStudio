<UserControl x:Class="DWMStudio.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DWMStudio.Views"
             Background="{StaticResource DwmShellBrush}">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="32 24 32 8">
            <StackPanel>
                <TextBlock Text="Worlds" Style="{StaticResource SectionHeaderStyle}" />
                <TextBlock Style="{StaticResource MutedLabelStyle}" Margin="0 4 0 0">
                    <Run Text="{Binding Worlds.Count, Mode=OneWay}" />
                    <Run Text="worlds in your library" />
                </TextBlock>
            </StackPanel>
        </Border>

      <Border DockPanel.Dock="Top" Padding="32 0 32 12">
        <Button Content="Export Test Package"
                Command="{Binding ExportTestPackageCommand}"
                Style="{StaticResource GhostButtonStyle}"
                HorizontalAlignment="Left" />
      </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32 16 32 32">
            <ItemsControl ItemsSource="{Binding Worlds}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:WorldCard Width="280"
                                         OpenWorldCommand="{Binding DataContext.OpenWorldCommand,
                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
