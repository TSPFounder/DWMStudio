<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pipeline stage + shell brushes -->
    <SolidColorBrush x:Key="DwmShellBrush"   Color="#1A1D21" />
    <SolidColorBrush x:Key="DwmNavBrush"     Color="#13161A" />
    <SolidColorBrush x:Key="DwmCardBrush"    Color="#22262C" />
    <SolidColorBrush x:Key="DwmDividerBrush" Color="#2E333B" />
    <SolidColorBrush x:Key="DwmMutedBrush"   Color="#5A6070" />
    <SolidColorBrush x:Key="DwmSysmlBrush"   Color="#7B68EE" />
    <SolidColorBrush x:Key="DwmCadBrush"     Color="#00BCD4" />
    <SolidColorBrush x:Key="DwmSimBrush"     Color="#26A69A" />
    <SolidColorBrush x:Key="DwmCoSimBrush"   Color="#42A5F5" />
    <SolidColorBrush x:Key="DwmRuntimeBrush" Color="#66BB6A" />
    <SolidColorBrush x:Key="DwmSuccessBrush" Color="#66BB6A" />
    <SolidColorBrush x:Key="DwmErrorBrush"   Color="#EF5350" />

    <!-- Fonts -->
    <FontFamily x:Key="DwmDisplayFont">Segoe UI</FontFamily>
    <FontFamily x:Key="DwmBodyFont">Segoe UI</FontFamily>
    <FontFamily x:Key="DwmMonoFont">Consolas</FontFamily>

    <!-- Text styles -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DwmDisplayFont}" />
        <Setter Property="FontSize"   Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#E0E4EC" />
    </Style>

    <Style x:Key="MutedLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DwmBodyFont}" />
        <Setter Property="FontSize"   Value="11" />
        <Setter Property="Foreground" Value="{StaticResource DwmMutedBrush}" />
    </Style>

    <!-- Nav buttons -->
    <Style x:Key="NavItemStyle" TargetType="Button">
        <Setter Property="Background"  Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground"  Value="#9AA3B0" />
        <Setter Property="FontSize"    Value="13" />
        <Setter Property="Height"      Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding"     Value="16 0" />
        <Setter Property="Cursor"      Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1E2228" />
                <Setter Property="Foreground" Value="#E0E4EC" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- World card -->
    <Style x:Key="WorldCardStyle" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource DwmCardBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Margin"       Value="0 0 12 12" />
        <Setter Property="Cursor"       Value="Hand" />
    </Style>

    <!-- Primary button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DwmCadBrush}" />
        <Setter Property="Foreground" Value="#111418" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="Padding"    Value="20 8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor"     Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00ACC1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost button -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Foreground"      Value="#9AA3B0" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="Padding"         Value="12 6" />
        <Setter Property="BorderBrush"     Value="{StaticResource DwmDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor"          Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2F37" />
                            <Setter Property="Foreground" Value="#E0E4EC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
