<Window x:Class="DWMStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DWMStudio.ViewModels"
        xmlns:views="clr-namespace:DWMStudio.Views"
        Title="DWM Studio"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DwmShellBrush}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- View → ViewModel routing -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
            <views:LibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorldDetailViewModel}">
            <views:WorldDetailView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Main shell -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <!-- Left nav -->
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                    Background="{StaticResource DwmNavBrush}">
                <DockPanel>
                    <!-- Wordmark -->
                    <Border DockPanel.Dock="Top" Padding="20 24 20 20">
                        <StackPanel>
                            <TextBlock Text="DWM"
                                       FontFamily="{StaticResource DwmDisplayFont}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource DwmCadBrush}" />
                            <TextBlock Text="Studio"
                                       FontSize="11"
                                       Foreground="{StaticResource DwmMutedBrush}"
                                       Margin="0 -2 0 0" />
                        </StackPanel>
                    </Border>

                    <Rectangle DockPanel.Dock="Top" Height="1"
                               Fill="{StaticResource DwmDividerBrush}" />

                    <StackPanel DockPanel.Dock="Top" Margin="0 8 0 0">
                        <Button Content="Dashboard"
                                Command="{Binding NavigateDashboardCommand}"
                                Style="{StaticResource NavItemStyle}" />
                        <Button Content="Library"
                                Command="{Binding NavigateLibraryCommand}"
                                Style="{StaticResource NavItemStyle}" />
                    </StackPanel>

                    <!-- New World button at bottom -->
                    <Border DockPanel.Dock="Bottom" Padding="12">
                        <Button Content="+ New World"
                                Command="{Binding Dashboard.OpenNewWorldWizardCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch" />
                    </Border>

                    <Grid />
                </DockPanel>
            </Border>

            <!-- Workspace -->
            <ContentControl Grid.Column="1" Grid.Row="0"
                            Content="{Binding CurrentView}" />

            <!-- Status bar -->
            <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                    Background="#111418"
                    BorderBrush="{StaticResource DwmDividerBrush}"
                    BorderThickness="0 1 0 0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16 0">
                    <views:ToolStatusDot Label="Fusion"
                                         IsConnected="{Binding ToolStatus.FusionConnected}" />
                    <views:ToolStatusDot Label="MATLAB"
                                         IsConnected="{Binding ToolStatus.MatlabConnected}"
                                         Margin="16 0 0 0" />
                    <views:ToolStatusDot Label="UModel"
                                         IsConnected="{Binding ToolStatus.UmodelConnected}"
                                         Margin="16 0 0 0" />
                    <views:ToolStatusDot Label="Unreal"
                                         IsConnected="{Binding ToolStatus.UnrealConnected}"
                                         Margin="16 0 0 0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Wizard overlay -->
        <Grid Visibility="{Binding IsWizardOpen,
                  Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#B0000000" />
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="720" MaxHeight="620"
                    Background="{StaticResource DwmCardBrush}"
                    CornerRadius="8">
                <views:NewWorldWizardView DataContext="{Binding Wizard}" />
            </Border>
        </Grid>
    </Grid>
</Window>
